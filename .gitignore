# ── Python ───────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.python-version
.ipynb_checkpoints/

# ── OS / editor ──────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# ── Data (open-access demo is redistributable, but keep the
#    repo lean; full MIMIC-IV is gated and must NEVER be committed) ──
project_sentinel/data/raw/*
project_sentinel/data/interim/*
project_sentinel/data/processed/*
!project_sentinel/data/raw/.gitkeep
!project_sentinel/data/interim/.gitkeep
!project_sentinel/data/processed/.gitkeep
# The ward-demo test set is derived from the open-access MIMIC-IV demo (redistributable)
# and is required for the backend/app to run from a fresh clone, so it IS tracked.
!project_sentinel/data/processed/test.parquet

# Loose MIMIC demo download outside the data/ tree (downloader default)
mimic_iv_demo/
mimic_demo_project/mimic_iv_demo/

# ── Model + output artifacts ─────────────────────────────
# Full-data models (~20 MB) live in git for now. RE-IGNORE this dir if the models
# grow past GitHub's 100 MB limit — they belong on HF Hub at that point.
# project_sentinel/models/
# Full-data evaluation reports, figures, and SHAP alerts ARE committed — they're the
# capstone evidence and are small (<2 MB total). Only the scratch models/ subdir is ignored.
project_sentinel/outputs/models/*
